# ============================================================
# Environment Variables — AMLO Monorepo
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ============================================================

# ── Database (PostgreSQL) ──
DB_PASSWORD=12345

# ── Backend ──
DATABASE_URL=postgresql://postgres:${DB_PASSWORD:-12345}@localhost:5432/backend_amlo
JWT_SECRET=key_pass_of_amlo
MASTER_KEY=your-master-key-for-supervisor-creation

# SMTP (email) — Ethereal for dev, real SMTP for prod
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Backend port (used by Express)
PORT=8080

# ── Frontend (Vite) — must be prefixed with VITE_ ──
VITE_API_URL=http://localhost:8080
VITE_GA_MEASUREMENT_ID=G-R1M9Q1QMQS