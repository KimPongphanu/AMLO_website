# ============================================================
# Environment Variables — AMLO Monorepo
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
# ============================================================
# ⚠️ IMPORTANT: Change ALL default passwords and secrets before deploying!
# Using default values in production is a CRITICAL security risk.
# ============================================================

# ── Database (PostgreSQL) ──
# ⚠️ Generate a strong random password: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ── Backend ──
DATABASE_URL=postgresql://postgres:${DB_PASSWORD:-CHANGE_ME_GENERATE_STRONG_PASSWORD}@localhost:5432/backend_amlo
# ⚠️ Generate a strong JWT secret: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_JWT_SECRET
MASTER_KEY=CHANGE_ME_GENERATE_STRONG_MASTER_KEY

# SMTP (email) — Ethereal for dev, real SMTP for prod
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Sentry Error Tracking (DSN from sentry.io)
SENTRY_DSN=

# Backend port (used by Express)
PORT=8080

# ── Frontend (Vite) — must be prefixed with VITE_ ──
VITE_API_URL=http://localhost:8080
VITE_GA_MEASUREMENT_ID=G-R1M9Q1QMQS